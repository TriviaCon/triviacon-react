{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/env.d.ts",
    "src/renderer/control-panel/src/**/*",
    "src/renderer/control-panel/src/**/*.tsx",
    "src/renderer/game-screen/src/**/*",
    "src/renderer/game-screen/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/data/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/control-panel/src/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    }
  }
}
